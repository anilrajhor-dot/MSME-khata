  "calculation_formulas": [
    {
      "ratio": "MPBF Method I (Tandon Committee)",
      "formula": "min(75% x Current Assets, Current Assets - (Current Liabilities - CC))",
      "code_ref": "renderCMA5(), line ~4127-4146",
      "norm": "Working capital limit recommendation, WC limit > Rs.5 Cr"
    },
    {
      "ratio": "MPBF Method II",
      "formula": "75% x Current Assets - Total CL (incl. proposed CC)",
      "code_ref": "renderCMA5(), line ~4151+",
      "norm": "Alternative Tandon method, higher promoter margin"
    },
    {
      "ratio": "Current Ratio",
      "formula": "Current Assets / Current Liabilities",
      "code_ref": "dataRow('Current Ratio', ...)",
      "norm": ">= 1.25 (bank norm), >=1.33 ideal"
    },
    {
      "ratio": "TOL/TNW",
      "formula": "(Total Liabilities - Net Worth) / Tangible Net Worth",
      "code_ref": "line ~4250, ~6421",
      "norm": "<= 3:1 (some covenants allow up to 4:1)"
    },
    {
      "ratio": "DSCR (Risk Rating module)",
      "formula": "(Cash Accrual + TL Interest) / (TL Interest + TL Principal, user-entered per year)",
      "code_ref": "computeRiskRating(), line ~6435-6442",
      "norm": ">= 1.25-1.5 depending on covenant"
    }
  ],
